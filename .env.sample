# Relationship system identity
BOT_ID=ao

# Main queue file that the response agent reads
RELATIONSHIP_QUEUE_FILE=../../data/queues/ao.json
RELATIONSHIP_CHANNEL_ID=replace_with_relationship_output_channel_id
RELATIONSHIP_THREAD_IDS=discord-channel-id:scheduled,discord-channel-id:user-id
RELATIONSHIP_STORE_DIR=../../data/relationship-system
RELATIONSHIP_POLICY_SCOPE_MODE=thread
RELATIONSHIP_USER_SCOPE_MISSING_USER_ID_MODE=fallback_thread
RELATIONSHIP_MAX_TURNS_PER_THREAD=200
RELATIONSHIP_RECENT_TURN_LIMIT=4
RELATIONSHIP_POLICY_LEARNING_TURN_LIMIT=8
RELATIONSHIP_EXECUTION_MODE_LEARNING_TURN_LIMIT=16
RELATIONSHIP_DISPATCH_SUPPRESSION_WINDOW_MS=7200000
RELATIONSHIP_MIN_TURN_AGE_MS_BEFORE_LOW_PRIORITY_DISPATCH=600000
RELATIONSHIP_BACKGROUND_POLL_MS=60000
RELATIONSHIP_ENQUEUE_COOLDOWN_MS=3600000

# Memory system backend
POSTGRES_URL=postgresql://app_user:app_password@localhost:5432/chat_agent

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_API_KEY=

# Fallback only when RELATIONSHIP_CHANNEL_ID is omitted
MENTION_CHANNEL_ID=replace_with_mention_channel_id
